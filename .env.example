# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=securevision_secret_key

# Database Configuration (MongoDB Atlas recommended for Vercel)
MONGODB_URI=mongodb://localhost:27017/task-cctv

# Cloudinary Configuration (REQUIRED for Vercel persistent image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
